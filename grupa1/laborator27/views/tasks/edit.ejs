<%- include('../partials/head', { title: 'Editează Sarcina' }) %>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
        <div class="bg-indigo-600 px-6 py-4 flex justify-between items-center">
            <h1 class="text-xl font-bold text-white">Editează Sarcina #<%= task.id %></h1>
            <span class="text-xs text-indigo-100 italic">Creată la: <%= new Date(task.created_at).toLocaleDateString('ro-RO') %></span>
        </div>

        <form action="/tasks/<%= task.id %>/update" method="POST" class="p-6 space-y-6">
            
            <div>
                <label for="title" class="block text-sm font-semibold text-gray-700 mb-1">Titlul sarcinii</label>
                <input type="text" id="title" name="title" value="<%= task.title %>" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition">
            </div>

            <div>
                <label for="description" class="block text-sm font-semibold text-gray-700 mb-1">Descriere detaliată</label>
                <textarea id="description" name="description" rows="4" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"><%= task.description %></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="status" class="block text-sm font-semibold text-gray-700 mb-1">Status</label>
                    <select id="status" name="status"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition">
                        <option value="pending" <%= task.status === 'pending' ? 'selected' : '' %>>În așteptare</option>
                        <option value="in_progress" <%= task.status === 'in_progress' ? 'selected' : '' %>>În lucru</option>
                        <option value="completed" <%= task.status === 'completed' ? 'selected' : '' %>>Finalizat</option>
                    </select>
                </div>

                <div>
                    <label for="priority" class="block text-sm font-semibold text-gray-700 mb-1">Prioritate</label>
                    <select id="priority" name="priority"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition">
                        <option value="low" <%= task.priority === 'low' ? 'selected' : '' %>>Scăzută</option>
                        <option value="medium" <%= task.priority === 'medium' ? 'selected' : '' %>>Medie</option>
                        <option value="high" <%= task.priority === 'high' ? 'selected' : '' %>>Ridicată</option>
                    </select>
                </div>
            </div>

            <div>
                <label for="deadline" class="block text-sm font-semibold text-gray-700 mb-1">Termen limită (Deadline)</label>
                <% 
                    // Formatăm data YYYY-MM-DD pentru input-ul de tip date
                    const deadlineFormatted = new Date(task.deadline).toISOString().split('T')[0]; 
                %>
                <input type="date" id="deadline" name="deadline" value="<%= deadlineFormatted %>" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition">
            </div>

            <div class="flex items-center justify-end space-x-4 pt-4 border-t border-gray-100">
                <a href="/tasks" class="text-gray-600 hover:text-gray-800 font-medium transition">
                    Anulează
                </a>
                <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-6 rounded-lg shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5">
                    Actualizează Sarcina
                </button>
            </div>

        </form>
    </div>
</div>

<%- include('../partials/footer') %>