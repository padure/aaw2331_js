<%- include('partials/head', { title: 'Dashboard Simplu' }) %>

<div class="container mx-auto px-4 py-12 max-w-6xl">
    <header class="mb-10">
        <h1 class="text-3xl font-light text-gray-800">Salutare!</h1>
        <p class="text-gray-500 mt-1">Iată situația sarcinilor tale pentru astăzi.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
        <div class="bg-white border border-gray-100 p-6 rounded-xl shadow-sm">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Total</span>
            <div class="text-3xl font-semibold text-gray-800 mt-1"><%= tasks.length %></div>
        </div>
        
        <div class="bg-white border border-gray-100 p-6 rounded-xl shadow-sm">
            <span class="text-xs font-bold text-blue-500 uppercase tracking-wider">În Lucru</span>
            <div class="text-3xl font-semibold text-gray-800 mt-1">
                <%= tasks.filter(t => t.status === 'in_progress').length %>
            </div>
        </div>

        <div class="bg-white border border-gray-100 p-6 rounded-xl shadow-sm">
            <span class="text-xs font-bold text-yellow-500 uppercase tracking-wider">În Așteptare</span>
            <div class="text-3xl font-semibold text-gray-800 mt-1">
                <%= tasks.filter(t => t.status === 'pending').length %>
            </div>
        </div>

        <div class="bg-white border border-gray-100 p-6 rounded-xl shadow-sm">
            <span class="text-xs font-bold text-green-500 uppercase tracking-wider">Finalizate</span>
            <div class="text-3xl font-semibold text-gray-800 mt-1">
                <%= tasks.filter(t => t.status === 'completed').length %>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden mb-12">
        <div class="px-6 py-4 border-b border-gray-50 flex justify-between items-center">
            <h3 class="font-medium text-gray-700">Sarcini prioritare</h3>
            <a href="/tasks" class="text-sm text-blue-600 hover:underline">Vezi tot</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <tbody class="divide-y divide-gray-50">
                    <% const urgentTasks = tasks.filter(t => t.status !== 'completed').slice(0, 5); %>
                    <% urgentTasks.forEach(task => { %>
                        <tr class="hover:bg-gray-50/50">
                            <td class="px-6 py-4">
                                <div class="text-sm font-medium text-gray-800"><%= task.title %></div>
                            </td>
                            <td class="px-6 py-4 text-right text-xs">
                                <span class="px-2 py-1 rounded <%= task.priority === 'high' ? 'bg-red-50 text-red-600' : 'bg-gray-50 text-gray-500' %>">
                                    <%= task.priority.toUpperCase() %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-8">
        <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-6 text-center">Recent Finalizate</h3>
        <div class="swiper completedTasksSwiper !pb-10">
            <div class="swiper-wrapper">
                <% tasks.filter(t => t.status === 'completed').forEach(task => { %>
                    <div class="swiper-slide">
                        <div class="bg-white border border-gray-100 p-4 rounded-lg text-center h-full">
                            <div class="w-8 h-8 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <div class="text-sm font-medium text-gray-700 truncate"><%= task.title %></div>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        new Swiper('.completedTasksSwiper', {
            slidesPerView: 2,
            spaceBetween: 15,
            pagination: { el: '.swiper-pagination', clickable: true },
            breakpoints: {
                768: { slidesPerView: 3 },
                1024: { slidesPerView: 5 }
            }
        });
    });
</script>

<style>
    .swiper-pagination-bullet { width: 6px; height: 6px; }
    .swiper-pagination-bullet-active { background: #cbd5e1 !important; }
</style>

<%- include('partials/footer') %>