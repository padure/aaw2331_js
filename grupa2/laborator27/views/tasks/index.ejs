<%- include('../partials/head', { title: 'Dashboard Sarcini' }) %>

<div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Sarcini Curente</h1>
            <p class="text-gray-500 mt-1">Gestionează fluxul de lucru și prioritățile echipei.</p>
        </div>
        <a href="/tasks/create" class="inline-flex items-center px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg shadow-sm transition-all duration-200 focus:ring-4 focus:ring-indigo-200">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Adaugă Sarcină
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-gray-600 italic">Detalii Sarcină</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-gray-600 italic text-center">Prioritate</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-gray-600 italic text-center">Status</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-gray-600 italic">Termen</th>
                        <th class="px-6 py-4 text-xs font-semibold uppercase text-gray-600 text-right">Acțiuni</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <% if (tasks.length > 0) { %>
                        <% tasks.forEach(task => { %>
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-800"><%= task.title %></div>
                                    <div class="text-sm text-gray-500 max-w-xs truncate"><%= task.description %></div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <% 
                                        const pColor = { 
                                            high: 'bg-red-50 text-red-700 border-red-100', 
                                            medium: 'bg-amber-50 text-amber-700 border-amber-100', 
                                            low: 'bg-emerald-50 text-emerald-700 border-emerald-100' 
                                        }[task.priority];
                                    %>
                                    <span class="px-2.5 py-0.5 rounded-full text-xs font-bold border <%= pColor %> uppercase">
                                        <%= task.priority %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center text-sm font-medium text-gray-600">
                                    <span class="flex items-center justify-center">
                                        <span class="h-2 w-2 rounded-full mr-2 <%= task.status === 'completed' ? 'bg-green-500' : (task.status === 'in_progress' ? 'bg-blue-500' : 'bg-gray-400') %>"></span>
                                        <%= task.status.replace('_', ' ') %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700 font-mono">
                                    <%= new Date(task.deadline).toLocaleDateString('ro-RO') %>
                                </td>
                                <td class="px-6 py-4 text-right space-x-2">
                                    <div class="inline-flex items-center">
                                        <a href="/tasks/<%= task.id %>/edit" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Editează">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </a>
                                        <form action="/tasks/<%= task.id %>/delete" method="POST" onsubmit="return confirm('Ești sigur că vrei să elimini această sarcină?');" class="inline">
                                            <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Șterge">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center">
                                    <svg class="w-12 h-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                                    <p class="text-gray-500 font-medium">Nu există sarcini active.</p>
                                    <a href="/tasks/create" class="text-indigo-600 hover:underline text-sm mt-2">Creează prima ta sarcină</a>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>