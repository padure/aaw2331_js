<%- include('../partials/head', { title: 'Adaugă Sarcină Nouă' }) %>

<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <nav class="flex mb-5 text-gray-500 text-sm" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1">
                <li class="inline-flex items-center">
                    <a href="/tasks" class="hover:text-indigo-600 transition-colors">Sarcini</a>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"></path></svg>
                        <span class="text-gray-400 font-medium">Creare</span>
                    </div>
                </li>
            </ol>
        </nav>

        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="p-6 sm:p-8">
                <div class="flex items-center mb-6">
                    <div class="p-3 bg-indigo-100 rounded-lg mr-4">
                        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900">Creare Sarcină Nouă</h1>
                </div>

                <form action="/tasks" method="POST" class="space-y-6">
                    <div>
                        <label for="title" class="block text-sm font-semibold text-gray-700 mb-1">Titlu Sarcină</label>
                        <input type="text" name="title" id="title" placeholder="Ex: Finalizare raport lunar" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder-gray-400">
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-semibold text-gray-700 mb-1">Descriere Detaliată</label>
                        <textarea name="description" id="description" rows="4" placeholder="Descrie pașii necesari pentru această sarcină..." required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all placeholder-gray-400"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="status" class="block text-sm font-semibold text-gray-700 mb-1">Status Inițial</label>
                            <select name="status" id="status" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                                <option value="pending" selected>În așteptare (Pending)</option>
                                <option value="in_progress">În lucru</option>
                                <option value="completed">Finalizată</option>
                            </select>
                        </div>

                        <div>
                            <label for="priority" class="block text-sm font-semibold text-gray-700 mb-1">Prioritate</label>
                            <select name="priority" id="priority" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                                <option value="low">Scăzută (Low)</option>
                                <option value="medium" selected>Medie (Medium)</option>
                                <option value="high">Ridicată (High)</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label for="deadline" class="block text-sm font-semibold text-gray-700 mb-1">Termen Limită</label>
                        <input type="date" name="deadline" id="deadline" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>

                    <div class="flex items-center justify-end space-x-4 pt-4 border-t border-gray-100">
                        <a href="/tasks" class="text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors">
                            Renunță
                        </a>
                        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-8 rounded-lg shadow-md hover:shadow-lg transition-all duration-200">
                            Creează Sarcina
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>