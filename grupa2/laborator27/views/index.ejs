<%- include('partials/head', { title: 'Panou Statistici' }) %>

<div class="container mx-auto px-4 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Dashboard Statistici</h1>
        <p class="text-gray-500 mt-1">Sumarul activității și starea curentă a sarcinilor.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center transition-transform hover:scale-105">
            <div class="p-3 bg-indigo-100 rounded-lg mr-4 text-indigo-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Total Sarcini</p>
                <p class="text-2xl font-bold text-gray-900"><%= stats.total %></p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center transition-transform hover:scale-105">
            <div class="p-3 bg-green-100 rounded-lg mr-4 text-green-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Finalizate</p>
                <p class="text-2xl font-bold text-gray-900"><%= stats.completed %></p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center transition-transform hover:scale-105">
            <div class="p-3 bg-blue-100 rounded-lg mr-4 text-blue-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">În Lucru</p>
                <p class="text-2xl font-bold text-gray-900"><%= stats.in_progress %></p>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex items-center transition-transform hover:scale-105">
            <div class="p-3 bg-red-100 rounded-lg mr-4 text-red-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Urgențe (High)</p>
                <p class="text-2xl font-bold text-gray-900"><%= stats.high_priority %></p>
            </div>
        </div>
    </div>

    <div class="bg-indigo-700 rounded-2xl p-8 text-white shadow-xl flex flex-col md:flex-row justify-between items-center">
        <div class="mb-6 md:mb-0">
            <h2 class="text-2xl font-bold mb-2">Ești gata să fii productiv?</h2>
            <p class="text-indigo-100">Adaugă o sarcină nouă sau verifică lista curentă pentru a vedea progresul.</p>
        </div>
        <div class="flex space-x-4">
            <a href="/tasks" class="bg-white text-indigo-700 px-6 py-3 rounded-lg font-bold hover:bg-indigo-50 transition-colors shadow-lg">
                Vezi Sarcini
            </a>
            <a href="/tasks/create" class="bg-indigo-500 text-white border border-indigo-400 px-6 py-3 rounded-lg font-bold hover:bg-indigo-400 transition-colors">
                + Adaugă Nouă
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>